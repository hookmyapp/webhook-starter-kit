# --- Webhook receiving ---
VERIFY_TOKEN=hookmyapp-verify
PORT=3000

# --- WhatsApp API (sending) ---
# Sandbox defaults below. For production, swap these three values:
#   WHATSAPP_API_URL       -> https://graph.facebook.com/v22.0
#   WHATSAPP_ACCESS_TOKEN  -> your Meta access token from `hookmyapp env <waba-id>`
#   WHATSAPP_PHONE_NUMBER_ID -> your phone number ID from `hookmyapp env <waba-id>`
WHATSAPP_API_URL=https://sandbox.hookmyapp.com/v22.0
WHATSAPP_ACCESS_TOKEN=your-activation-code
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
