# Webhook starter kit. Pull dynamic values with the HookMyApp CLI:
#   npm install -g @gethookmyapp/cli
#   hookmyapp login
#   hookmyapp sandbox env --write .env        (one channel per session)
# Run the kit with both blocks present to serve WhatsApp and Instagram at once.

VERIFY_TOKEN=your-sandbox-hmac-secret
PORT=3000

# WhatsApp block (sandbox env writes WHATSAPP_API_URL; production channels env writes META_GRAPH_API_URL, the kit accepts either)
WHATSAPP_API_URL=https://sandbox.hookmyapp.com/v22.0
WHATSAPP_ACCESS_TOKEN=your-sandbox-activation-code
WHATSAPP_PHONE_NUMBER_ID=your-sandbox-phone

# Instagram block (sandbox env writes INSTAGRAM_API_URL / INSTAGRAM_ACCOUNT_ID;
# a real Instagram channel's channels env writes INSTAGRAM_GRAPH_API_URL /
# INSTAGRAM_USER_ID instead. The kit reads either shape, so the same code runs
# against the sandbox and production unchanged.)
INSTAGRAM_API_URL=https://sandbox.hookmyapp.com/v25.0
INSTAGRAM_ACCESS_TOKEN=your-sandbox-activation-code
INSTAGRAM_ACCOUNT_ID=your-sandbox-ig-account-id

# ── Choose EXACTLY ONE transport. Do NOT set both. ──
# The kit resolves the base as  *_API_URL ?? *_GRAPH_API_URL  — so if a sandbox
# *_API_URL is set, it WINS and the gateway *_GRAPH_API_URL below is ignored.
#
# Sandbox (testing): set WHATSAPP_API_URL / INSTAGRAM_API_URL (and comment the gateway block).
# Production via the HookMyApp gateway: COMMENT OUT the sandbox *_API_URL lines and use:
#
# Production (real channel) — generate with: hookmyapp channels env --write .env
# META_GRAPH_API_URL is the HookMyApp gateway base; the kit appends /{id}/messages verbatim.
META_GRAPH_API_URL=https://gateway.hookmyapp.com/meta/v22.0
WHATSAPP_ACCESS_TOKEN=hmp_live_your_minted_key   # from: hookmyapp keys create <channel>
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Instagram production: INSTAGRAM_GRAPH_API_URL=https://gateway.hookmyapp.com/meta/v25.0
#   INSTAGRAM_ACCESS_TOKEN=hmp_live_... — a key minted for the INSTAGRAM channel's own
#   connection (run: hookmyapp keys create <instagram-channel>). API keys are per-connection,
#   so a WhatsApp channel's key does NOT authorize an Instagram connection.
# (When using the gateway block above, ensure WHATSAPP_API_URL / INSTAGRAM_API_URL are unset/commented.)
