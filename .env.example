# Webhook starter kit — sandbox defaults.
# Pull the dynamic values with the HookMyApp CLI:
#   npm install -g @gethookmyapp/cli
#   hookmyapp login
#   hookmyapp sandbox env --write .env
# (The CLI writes these exact keys with your session's dynamic values.)

# VERIFY_TOKEN is your sandbox session's hmacSecret. Get it from `hookmyapp sandbox env`.
VERIFY_TOKEN=your-sandbox-hmac-secret

PORT=3000

# Sandbox endpoints — the CLI fills these in for you via `hookmyapp sandbox env --write`.
WHATSAPP_API_URL=https://sandbox.hookmyapp.com/v22.0
WHATSAPP_ACCESS_TOKEN=your-sandbox-activation-code
WHATSAPP_PHONE_NUMBER_ID=your-sandbox-phone
